{
  "id": "neo4j-memory",
  "kind": "memory",
  "description": "Neo4j native memory plugin with auto-recall and auto-capture",
  "version": "0.1.0",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "neo4j": {
        "type": "object",
        "properties": {
          "uri": { "type": "string", "default": "bolt://localhost:7687" },
          "username": { "type": "string", "default": "neo4j" },
          "password": { "type": "string" },
          "database": { "type": "string", "default": "memory" },
          "vectorDimension": { "type": "number", "enum": [1536, 3072], "default": 1536 }
        },
        "required": ["uri", "username", "password"]
      },
      "embedding": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "enum": ["text-embedding-3-small", "text-embedding-3-large"] },
          "apiKey": { "type": "string" }
        },
        "required": ["apiKey"]
      },
      "autoRecall": { "type": "boolean", "default": true },
      "autoCapture": { "type": "boolean", "default": true },
      "captureMaxChars": { "type": "number", "minimum": 100, "maximum": 20000, "default": 500 },
      "recallLimit": { "type": "number", "minimum": 1, "maximum": 20, "default": 5 },
      "skipShortDuplicates": { "type": "boolean", "default": true }
    },
    "required": ["neo4j", "embedding"]
  }
}
